# Copie este arquivo para .env e ajuste conforme necessário:
#   cp .env.example .env
#   docker-compose up -d --build

# OBRIGATÓRIO: chave para Flask flash/sessão (gere com: openssl rand -hex 32)
SECRET_KEY=troque-isto-por-uma-string-aleatoria-de-32-bytes

# Porta exposta no host
HOST_PORT=5000

# Pasta no host que será montada em /mnt/nas/Downloads dentro do container
HOST_DOWNLOAD_PATH=/mnt/nas/Downloads

# UID/GID do usuário que vai rodar o app dentro do container.
# Use os mesmos do dono da pasta no host para evitar problemas de permissão.
# Descubra com: id -u  e  id -g
APP_UID=1000
APP_GID=1000

# Limites de uso
MAX_LINKS=500
MAX_UPLOAD_MB=1
MAX_JOBS_KEPT=20
